generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum Role {
  participant
  volunteer
  admin
  judge
}

enum RegistrationStatus {
  pending
  confirmed
  waitlisted
}

enum SubmissionStatus {
  draft
  submitted
  reviewed
}

enum SponsorTier {
  platinum
  gold
  silver
}

enum TimelineStatus {
  active
  upcoming
  completed
}

// ─── Auth.js adapter tables ────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core domain models ────────────────────────────────────────────────────

/// A person who has signed up. Role controls what they can access.
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // null for OAuth-only users
  role          Role      @default(participant)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Auth.js relations
  accounts  Account[]
  sessions  Session[]

  // Domain relations
  registration  Registration?
  teamMemberships TeamMember[]
  ledTeams      Team[]         @relation("TeamLeader")
  announcements Announcement[]
  checkInsPerformed CheckIn[]  @relation("CheckInPerformedBy")
  foodDistributionsPerformed FoodDistribution[] @relation("FoodDistributionPerformedBy")
  formResponse  FormResponse?
  volunteerRegistration VolunteerRegistration?
  judgingScores JudgingScore[]
}

/// Created when a user registers for the event.
/// One user → one registration.
model Registration {
  id              String             @id @default(cuid())
  userId          String             @unique
  status          RegistrationStatus @default(pending)
  waitlistPosition Int?              // Position in waitlist queue (null if not waitlisted)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticket Ticket?
}

/// Event capacity and settings
model EventSettings {
  id                String   @id @default("singleton")
  maxCapacity       Int      @default(100)
  registrationOpen  Boolean  @default(true)
  emailsEnabled     Boolean  @default(true)  // Super admin only - master kill switch for all emails
  allowSecondServings Boolean @default(false) // Allow participants to get food twice
  updatedAt         DateTime @updatedAt
  updatedBy         String?

  @@map("event_settings")
}

/// A QR-code ticket issued when a registration is confirmed.
/// One registration → one ticket.
model Ticket {
  id             String   @id @default(cuid())
  registrationId String   @unique
  qrToken        String   @unique @default(cuid())
  issuedAt       DateTime @default(now())

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  checkIn      CheckIn?
  foodDistributions FoodDistribution[]
}

/// Records the moment a ticket was scanned at the event entrance.
/// One ticket → at most one check-in (enforced by unique on ticketId).
model CheckIn {
  id          String   @id @default(cuid())
  ticketId    String   @unique
  performedBy String   // userId of the volunteer/admin who scanned
  checkedInAt DateTime @default(now())

  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  performer User   @relation("CheckInPerformedBy", fields: [performedBy], references: [id])
}

// ─── Food Tracking System ──────────────────────────────────────────────────

enum MealType {
  dinner
  midnight_snack
  breakfast
}

/// Records when a participant receives food
model FoodDistribution {
  id          String   @id @default(cuid())
  ticketId    String
  mealType    MealType
  servingNumber Int    // 1 for first serving, 2 for second serving
  performedBy String   // userId of the volunteer/admin who scanned
  distributedAt DateTime @default(now())

  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  performer User   @relation("FoodDistributionPerformedBy", fields: [performedBy], references: [id])

  @@index([ticketId, mealType])
  @@index([mealType])
}

/// A challenge category. Seeded from the landing page tracks.
/// visible = false means the detail page is hidden from public users.
/// slug is used as the URL path segment.
model Track {
  id              String  @id @default(cuid())
  slug            String  @unique
  name            String  @unique
  description     String  // short summary shown on landing page cards
  fullDescription String  // full detail shown on the track detail page
  promptContent   String  // challenge prompt/problem statement (released at event start)
  icon            String
  gradient        String
  order           Int     @default(0)
  visible         Boolean @default(false) // false = hidden from public

  teams       Team[]
  submissions Submission[]
}

/// A group of up to 4 participants competing together.
/// leaderId points to the User who created the team.
/// inviteCode is a short 6-char uppercase code for easy sharing.
model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  leaderId    String
  trackId     String?
  inviteCode  String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leader     User         @relation("TeamLeader", fields: [leaderId], references: [id])
  track      Track?       @relation(fields: [trackId], references: [id])
  members    TeamMember[]
  submission Submission?
}

/// Join table between User and Team.
/// A user can only be on one team at a time (enforced by unique on userId).
model TeamMember {
  id       String @id @default(cuid())
  teamId   String
  userId   String
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@unique([userId]) // one team per user
}

/// A project submitted by a team for judging.
/// One team → one submission (enforced by unique on teamId).
model Submission {
  id          String           @id @default(cuid())
  teamId      String           @unique
  trackId     String
  title       String
  description String
  repoUrl     String?
  demoUrl     String?
  videoUrl    String?
  status      SubmissionStatus @default(draft)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  team   Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  track  Track          @relation(fields: [trackId], references: [id])
  scores JudgingScore[]
}

// ─── Judging System ────────────────────────────────────────────────────────

/// Judging criteria configured by admins
model JudgingCriteria {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  maxScore    Int      @default(10)
  weight      Float    @default(1.0) // multiplier for final score calculation
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scores JudgingScore[]
}

/// Individual score given by a judge for a submission on a specific criteria
model JudgingScore {
  id           String   @id @default(cuid())
  submissionId String
  judgeId      String
  criteriaId   String
  score        Int      // 0 to maxScore
  comment      String?  // optional feedback
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submission Submission       @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  judge      User             @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  criteria   JudgingCriteria  @relation(fields: [criteriaId], references: [id], onDelete: Cascade)

  @@unique([submissionId, judgeId, criteriaId]) // one score per judge per criteria per submission
  @@index([submissionId])
  @@index([judgeId])
}

/// A message posted by an admin, visible to all participants on their dashboard.
model Announcement {
  id          String   @id @default(cuid())
  title       String
  body        String
  published   Boolean  @default(false)
  pinned      Boolean  @default(false)
  audience    String   @default("all") // "all", "registered", "volunteers", "admins", "waitlisted"
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User @relation(fields: [createdById], references: [id])
  sentTo    AnnouncementSent[]
}

/// Track which users have received which announcements (to prevent duplicates)
model AnnouncementSent {
  id             String   @id @default(cuid())
  announcementId String
  userEmail      String
  sentAt         DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userEmail])
  @@index([userEmail])
  @@index([announcementId])
}

// ─── Content / seed models ─────────────────────────────────────────────────

model Sponsor {
  id         String      @id @default(cuid())
  name       String
  initial    String
  tier       SponsorTier
  logoUrl    String?
  websiteUrl String?
  active     Boolean     @default(true)
  order      Int         @default(0)
}

model FAQ {
  id        String  @id @default(cuid())
  question  String
  answer    String
  order     Int     @default(0)
  published Boolean @default(true)
}

model TimelineEvent {
  id          String         @id @default(cuid())
  title       String
  date        String
  description String
  status      TimelineStatus @default(upcoming)
  order       Int            @default(0)
}

// ─── Form Builder System ───────────────────────────────────────────────────

enum QuestionType {
  text
  textarea
  email
  select
  radio
  checkbox
  file
}

/// A section in the registration form (e.g., "Basic Info", "Team Formation")
model FormSection {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions FormQuestion[]
}

/// A question in the registration form
model FormQuestion {
  id              String       @id @default(cuid())
  sectionId       String
  type            QuestionType
  label           String
  description     String?
  placeholder     String?
  required        Boolean      @default(false)
  options         String?      // JSON array for select/radio/checkbox options
  order           Int          @default(0)
  active          Boolean      @default(true)
  conditionalOn   String?      // questionId that controls visibility
  conditionalValue String?     // value that triggers visibility
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  section FormSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  answers FormAnswer[]
}

/// A complete form submission from a user
model FormResponse {
  id        String   @id @default(cuid())
  userId    String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers FormAnswer[]

  @@unique([userId]) // one response per user
}

/// An answer to a specific question
model FormAnswer {
  id         String   @id @default(cuid())
  responseId String
  questionId String
  value      String   // JSON for complex values (arrays, file metadata)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  response FormResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question FormQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([responseId, questionId]) // one answer per question per response
}

// ─── Volunteer Registration ────────────────────────────────────────────────

/// Volunteer form builder - sections
model VolunteerFormSection {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions VolunteerFormQuestion[]
}

/// Volunteer form builder - questions
model VolunteerFormQuestion {
  id              String       @id @default(cuid())
  sectionId       String
  type            QuestionType
  label           String
  description     String?
  placeholder     String?
  required        Boolean      @default(false)
  options         String?      // JSON array for select/radio/checkbox options
  order           Int          @default(0)
  active          Boolean      @default(true)
  conditionalOn   String?      // questionId that controls visibility
  conditionalValue String?     // value that triggers visibility
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  section VolunteerFormSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  answers VolunteerFormAnswer[]
}

/// Volunteer registration form submission
model VolunteerRegistration {
  id        String   @id @default(cuid())
  userId    String   @unique
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers VolunteerFormAnswer[]
}

/// Answer to a volunteer form question
model VolunteerFormAnswer {
  id             String   @id @default(cuid())
  registrationId String
  questionId     String
  value          String   // JSON for complex values (arrays, file metadata)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  registration VolunteerRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  question     VolunteerFormQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([registrationId, questionId]) // one answer per question per registration
}
