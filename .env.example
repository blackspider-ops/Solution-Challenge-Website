# Database
DATABASE_URL="file:./prisma/dev.db"  # SQLite for local dev
# DATABASE_URL="postgresql://user:password@host:5432/dbname"  # PostgreSQL for production

# Auth.js
AUTH_SECRET="your-secret-key-here"  # Generate with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"  # Change to your production URL

# Email (Resend)
RESEND_API_KEY="re_your_api_key_here"  # Get from resend.com
EMAIL_FROM="Solution Challenge <noreply@yourdomain.com>"  # Your from email

# OAuth Providers (optional)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# OAuth Providers - Public (for client-side detection)
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id"
NEXT_PUBLIC_GITHUB_CLIENT_ID="your-github-client-id"

# Social Media Links
NEXT_PUBLIC_TWITTER_URL="https://twitter.com/gdgpennstate"
NEXT_PUBLIC_GITHUB_URL="https://github.com/gdgpennstate"
NEXT_PUBLIC_LINKEDIN_URL="https://linkedin.com/company/gdgpennstate"
NEXT_PUBLIC_YOUTUBE_URL="https://youtube.com/@gdgpennstate"
